// ── Visual constants ── only file to touch for branding ──────────

#let accent       = rgb("#1a1a2e")      // dark navy — section headings
#let rule-color   = rgb("#2d2d2d")      // horizontal rule color
#let muted        = rgb("#555555")      // gray sub-text (involvement, dates)

#let body-font    = ("Georgia",)
#let name-size    = 18pt   // LaTeX \LARGE at 10pt base = 17.28pt
#let section-size = 10pt       // same as body — just bold uppercase
#let body-size    = 10pt

// Match original LaTeX margins exactly: left=0.3in, top=0.2in, right=0.3in, bottom=0.2in
#let page-margins = (
  top:    0.2in,
  bottom: 0.2in,
  left:   0.3in,
  right:  0.3in,
)

